{
  "name": "@airsign/wallet-adapter",
  "version": "1.0.0",
  "description": "AirSign wallet adapter — air-gapped Solana signing via animated QR codes. Implements @solana/wallet-adapter-base (works with Raydium, Jupiter, Magic Eden, Tensor, and any wallet-adapter-react dApp).",
  "keywords": [
    "solana",
    "wallet-adapter",
    "airsign",
    "air-gapped",
    "hardware-wallet",
    "qr-code",
    "signing"
  ],
  "license": "MIT",
  "author": "nzengi",
  "repository": {
    "type": "git",
    "url": "https://github.com/nzengi/AirSign.git",
    "directory": "packages/wallet-adapter"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@solana/wallet-adapter-base": ">=0.9.0",
    "@solana/web3.js": ">=1.90.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@airsign/react": ">=1.0.0"
  },
  "devDependencies": {
    "@airsign/react": "*",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/web3.js": "^1.95.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}